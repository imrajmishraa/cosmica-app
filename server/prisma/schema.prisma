datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  assets        Asset[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Asset {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName      String
  originalName  String
  mimeType      String
  size          Int
  path          String
  thumbnailPath String?
  mediumPath    String?
  metadata      Json?    // Stores dimensions, EXIF data, GPS coordinates, camera details
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
